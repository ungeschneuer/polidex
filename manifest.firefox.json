{
  "manifest_version": 3,
  "name": "Polidex",
  "version": "0.9.1",
  "description": "Sammle Politiker*innen in Nachrichtenartikeln",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://ungeschneuer.github.io/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "polidex@ungeschneuer.de",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; frame-src 'none'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "exclude_matches": [
        "*://*.spd.de/*",
        "*://*.cdu.de/*",
        "*://*.csu.de/*",
        "*://*.gruene.de/*",
        "*://*.fdp.de/*",
        "*://*.afd.de/*",
        "*://*.buendnis-sahra-wagenknecht.de/*",
        "*://*.bsw-vg.de/*",
        "*://*.die-linke.de/*",
        "*://*.bundestag.de/*",
        "*://*.bundesregierung.de/*",
        "*://*.bundesrat.de/*",
        "*://*.abgeordnetenwatch.de/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
